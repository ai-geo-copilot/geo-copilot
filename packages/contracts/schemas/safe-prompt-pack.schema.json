{
  "$defs": {
    "PublicReadinessScore": {
      "properties": {
        "score": {
          "title": "Score",
          "type": "number"
        },
        "status": {
          "enum": [
            "strong",
            "mixed",
            "weak"
          ],
          "title": "Status",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        }
      },
      "required": [
        "score",
        "status"
      ],
      "title": "PublicReadinessScore",
      "type": "object"
    },
    "PublicStructuredDataProfile": {
      "properties": {
        "primary_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Primary Type"
        },
        "visible_alignment": {
          "default": "unknown",
          "enum": [
            "good",
            "partial",
            "poor",
            "unknown"
          ],
          "title": "Visible Alignment",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        }
      },
      "title": "PublicStructuredDataProfile",
      "type": "object"
    },
    "RetrievalQuery": {
      "properties": {
        "page_type": {
          "enum": [
            "article",
            "product",
            "docs",
            "landing",
            "comparison",
            "home",
            "unknown"
          ],
          "title": "Page Type",
          "type": "string"
        },
        "failed_rule_ids": {
          "items": {
            "type": "string"
          },
          "title": "Failed Rule Ids",
          "type": "array"
        },
        "warning_rule_ids": {
          "items": {
            "type": "string"
          },
          "title": "Warning Rule Ids",
          "type": "array"
        },
        "failure_types": {
          "items": {
            "type": "string"
          },
          "title": "Failure Types",
          "type": "array"
        }
      },
      "required": [
        "page_type"
      ],
      "title": "RetrievalQuery",
      "type": "object"
    },
    "RetrievedMethodChunk": {
      "properties": {
        "method_ref": {
          "title": "Method Ref",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        },
        "why_selected": {
          "title": "Why Selected",
          "type": "string"
        },
        "matched_rule_ids": {
          "items": {
            "type": "string"
          },
          "title": "Matched Rule Ids",
          "type": "array"
        },
        "matched_failure_types": {
          "items": {
            "type": "string"
          },
          "title": "Matched Failure Types",
          "type": "array"
        },
        "matched_evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Matched Evidence Refs",
          "type": "array"
        },
        "strategy_group": {
          "title": "Strategy Group",
          "type": "string"
        },
        "expected_artifacts": {
          "items": {
            "type": "string"
          },
          "title": "Expected Artifacts",
          "type": "array"
        },
        "guardrails": {
          "items": {
            "type": "string"
          },
          "title": "Guardrails",
          "type": "array"
        },
        "score": {
          "title": "Score",
          "type": "integer"
        }
      },
      "required": [
        "method_ref",
        "title",
        "text",
        "why_selected",
        "strategy_group",
        "score"
      ],
      "title": "RetrievedMethodChunk",
      "type": "object"
    },
    "RetrievedMethodPack": {
      "properties": {
        "pack_version": {
          "default": "retrieved-method-pack-v0",
          "title": "Pack Version",
          "type": "string"
        },
        "compiled_method_pack_version": {
          "title": "Compiled Method Pack Version",
          "type": "string"
        },
        "selection_mode": {
          "const": "deterministic_v0",
          "default": "deterministic_v0",
          "title": "Selection Mode",
          "type": "string"
        },
        "retrieval_query": {
          "$ref": "#/$defs/RetrievalQuery"
        },
        "chunks": {
          "items": {
            "$ref": "#/$defs/RetrievedMethodChunk"
          },
          "title": "Chunks",
          "type": "array"
        }
      },
      "required": [
        "compiled_method_pack_version",
        "retrieval_query",
        "chunks"
      ],
      "title": "RetrievedMethodPack",
      "type": "object"
    },
    "RuleCheck": {
      "properties": {
        "rule_id": {
          "title": "Rule Id",
          "type": "string"
        },
        "severity": {
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "title": "Severity",
          "type": "string"
        },
        "status": {
          "enum": [
            "passed",
            "failed",
            "warning"
          ],
          "title": "Status",
          "type": "string"
        },
        "finding": {
          "title": "Finding",
          "type": "string"
        },
        "failure_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Failure Type"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "recommendation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Recommendation"
        }
      },
      "required": [
        "rule_id",
        "severity",
        "status",
        "finding"
      ],
      "title": "RuleCheck",
      "type": "object"
    },
    "SafeEvidenceExcerpt": {
      "properties": {
        "evidence_ref": {
          "title": "Evidence Ref",
          "type": "string"
        },
        "text": {
          "maxLength": 500,
          "title": "Text",
          "type": "string"
        },
        "source": {
          "enum": [
            "content_block",
            "heading",
            "table",
            "claim_candidate",
            "statistic_candidate"
          ],
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "evidence_ref",
        "text",
        "source"
      ],
      "title": "SafeEvidenceExcerpt",
      "type": "object"
    },
    "SafePrimaryEntity": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "entity_type": {
          "enum": [
            "Product",
            "Organization",
            "Article",
            "WebPage",
            "Unknown"
          ],
          "title": "Entity Type",
          "type": "string"
        },
        "confidence": {
          "title": "Confidence",
          "type": "number"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        }
      },
      "required": [
        "name",
        "entity_type",
        "confidence"
      ],
      "title": "SafePrimaryEntity",
      "type": "object"
    },
    "SafeProfileFacts": {
      "properties": {
        "page_type": {
          "enum": [
            "article",
            "product",
            "docs",
            "landing",
            "comparison",
            "home",
            "unknown"
          ],
          "title": "Page Type",
          "type": "string"
        },
        "page_type_evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Page Type Evidence Refs",
          "type": "array"
        },
        "primary_entity": {
          "anyOf": [
            {
              "$ref": "#/$defs/SafePrimaryEntity"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "selection_readiness": {
          "$ref": "#/$defs/PublicReadinessScore"
        },
        "absorption_readiness": {
          "$ref": "#/$defs/PublicReadinessScore"
        },
        "prompt_injection_risk": {
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "title": "Prompt Injection Risk",
          "type": "string"
        },
        "structured_data": {
          "$ref": "#/$defs/PublicStructuredDataProfile"
        },
        "content_gaps": {
          "items": {
            "type": "string"
          },
          "title": "Content Gaps",
          "type": "array"
        }
      },
      "required": [
        "page_type",
        "selection_readiness",
        "absorption_readiness",
        "prompt_injection_risk",
        "structured_data"
      ],
      "title": "SafeProfileFacts",
      "type": "object"
    },
    "SafePromptSafetyPolicy": {
      "properties": {
        "forbidden_inputs": {
          "items": {
            "type": "string"
          },
          "title": "Forbidden Inputs",
          "type": "array"
        },
        "required_bindings": {
          "items": {
            "type": "string"
          },
          "title": "Required Bindings",
          "type": "array"
        },
        "unknown_handling": {
          "items": {
            "type": "string"
          },
          "title": "Unknown Handling",
          "type": "array"
        }
      },
      "title": "SafePromptSafetyPolicy",
      "type": "object"
    },
    "StrategyPlan": {
      "properties": {
        "plan_version": {
          "default": "strategy-plan-v0",
          "title": "Plan Version",
          "type": "string"
        },
        "planner_version": {
          "default": "strategy-planner-v0",
          "title": "Planner Version",
          "type": "string"
        },
        "strategy_steps": {
          "items": {
            "$ref": "#/$defs/StrategyStep"
          },
          "title": "Strategy Steps",
          "type": "array"
        }
      },
      "required": [
        "strategy_steps"
      ],
      "title": "StrategyPlan",
      "type": "object"
    },
    "StrategyStep": {
      "properties": {
        "step_id": {
          "title": "Step Id",
          "type": "string"
        },
        "strategy_group": {
          "title": "Strategy Group",
          "type": "string"
        },
        "rank": {
          "title": "Rank",
          "type": "integer"
        },
        "method_refs": {
          "items": {
            "type": "string"
          },
          "title": "Method Refs",
          "type": "array"
        },
        "rule_ids": {
          "items": {
            "type": "string"
          },
          "title": "Rule Ids",
          "type": "array"
        },
        "failure_types": {
          "items": {
            "type": "string"
          },
          "title": "Failure Types",
          "type": "array"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "why_now": {
          "title": "Why Now",
          "type": "string"
        },
        "expected_artifacts": {
          "items": {
            "type": "string"
          },
          "title": "Expected Artifacts",
          "type": "array"
        },
        "validator_requirements": {
          "items": {
            "type": "string"
          },
          "title": "Validator Requirements",
          "type": "array"
        }
      },
      "required": [
        "step_id",
        "strategy_group",
        "rank",
        "method_refs",
        "why_now"
      ],
      "title": "StrategyStep",
      "type": "object"
    }
  },
  "properties": {
    "pack_version": {
      "const": "safe-prompt-pack-v0",
      "default": "safe-prompt-pack-v0",
      "title": "Pack Version",
      "type": "string"
    },
    "input_url": {
      "title": "Input Url",
      "type": "string"
    },
    "normalized_url": {
      "title": "Normalized Url",
      "type": "string"
    },
    "facts": {
      "$ref": "#/$defs/SafeProfileFacts"
    },
    "rule_checks": {
      "items": {
        "$ref": "#/$defs/RuleCheck"
      },
      "title": "Rule Checks",
      "type": "array"
    },
    "retrieved_methods": {
      "$ref": "#/$defs/RetrievedMethodPack"
    },
    "strategy_plan": {
      "$ref": "#/$defs/StrategyPlan"
    },
    "evidence_excerpts": {
      "items": {
        "$ref": "#/$defs/SafeEvidenceExcerpt"
      },
      "title": "Evidence Excerpts",
      "type": "array"
    },
    "safety_policy": {
      "$ref": "#/$defs/SafePromptSafetyPolicy"
    },
    "validator_warnings": {
      "items": {
        "type": "string"
      },
      "title": "Validator Warnings",
      "type": "array"
    }
  },
  "required": [
    "input_url",
    "normalized_url",
    "facts",
    "retrieved_methods",
    "strategy_plan",
    "safety_policy"
  ],
  "title": "SafePromptPack",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://geo-copilot.local/schemas/safe-prompt-pack.schema.json"
}
