      "properties": {
        "parser": {
          "const": "selectolax",
          "default": "selectolax",
          "title": "Parser",
          "type": "string"
        },
        "structured_data_parser": {
          "const": "extruct",
          "default": "extruct",
          "title": "Structured Data Parser",
          "type": "string"
        },
        "main_content_extractor": {
          "const": "trafilatura",
          "default": "trafilatura",
          "title": "Main Content Extractor",
          "type": "string"
        },
        "clean_markdown_sha256": {
          "default": "",
          "title": "Clean Markdown Sha256",
          "type": "string"
        },
        "warnings": {
          "items": {
            "$ref": "#/$defs/ExtractionWarning"
