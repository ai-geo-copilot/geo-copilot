      "properties": {
        "final_url": {
          "title": "Final Url",
          "type": "string"
        },
        "status_code": {
          "title": "Status Code",
          "type": "integer"
        },
        "content_type": {
          "title": "Content Type",
          "type": "string"
        },
        "elapsed_ms": {
          "title": "Elapsed Ms",
