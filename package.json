{
  "name": "geo-copilot",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/contracts"
  ],
  "scripts": {
    "dev": "npm run dev:api && npm run dev:web",
    "dev:api": "python -m uvicorn apps.api.app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:web": "npm --workspace apps/web run dev",
    "test": "python -m pytest apps/api/tests && npm --workspace apps/web run typecheck",
    "typecheck": "npm --workspace apps/web run typecheck"
  }
}
